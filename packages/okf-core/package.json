{
  "name": "@okf/core",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Source-agnostic model + validator for Open Knowledge Format (OKF) bundles.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lorsabyan/okf-reader",
    "directory": "packages/okf-core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "bun": "./src/validate.ts",
      "default": "./dist/validate.js"
    }
  },
  "bin": {
    "okf-validate": "./bin/okf-validate.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build"
  },
  "dependencies": {
    "js-yaml": "5.2.1"
  }
}
