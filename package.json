  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "@types/bun": "1.3.14",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "pagefind": "1.5.2",
    "tailwindcss": "4.3.2",
    "typescript": "^5"
  }
