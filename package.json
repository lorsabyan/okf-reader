{
  "name": "okf-reader",
  "version": "0.2.0",
  "private": true,
  "packageManager": "bun@1.3.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && pagefind --site out",
    "start": "next start",
