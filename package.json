  "dependencies": {
    "@okf/core": "workspace:*",
    "@shikijs/rehype": "4.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "rehype-slug": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "shadcn": "4.13.0",
    "shiki": "4.3.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "unified": "11.0.5"
